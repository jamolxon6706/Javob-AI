# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://javobai:secret@localhost:5432/javobai
POSTGRES_USER=javobai
POSTGRES_PASSWORD=secret
POSTGRES_DB=javobai

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_64_char_string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
OTP_TTL_SECONDS=300

# ─── Auth cookies (Phase 6) ───────────────────────────────────────────────────
# COOKIE_SECURE=false in local dev (HTTP); true in prod (HTTPS).
# COOKIE_DOMAIN empty in dev; set to ".javobai.uz" in prod so the cookie crosses subdomains.
# COOKIE_SAMESITE lax (default), strict, or none.
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# ─── Encryption (Fernet key — run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=change_me_to_fernet_key

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_WEBHOOK_SECRET=change_me_random_32_chars

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=change_me_random_32_chars

# ─── AI / LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=15
EMBEDDINGS_MODEL=BAAI/bge-m3

# ─── Payments ────────────────────────────────────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_KEY=
PAYME_TEST_KEY=

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ─── Web (Phase 6) ───────────────────────────────────────────────────────────
# Server-only (no NEXT_PUBLIC_ prefix) — the browser never calls FastAPI
# directly. apps/web's Route Handlers (/api/auth/*, /api/proxy/*) read this
# to forward requests server-side and relay Set-Cookie back to the browser.
# NEXT_PUBLIC_API_URL is intentionally NOT used: exposing the API origin to
# the browser would invite people to bypass the BFF cookie/Bearer relay.
INTERNAL_API_BASE_URL=http://localhost:8000

# ─── Web (Phase 8) — operator inbox realtime ─────────────────────────────────
# The ONE exception to "the browser never calls FastAPI directly" (see
# javobai/ws/router.py): a websocket can't be proxied through a Next.js Route
# Handler, so the inbox opens this one directly from the browser, carrying a
# one-time ticket (not the JWT) minted via POST /auth/ws-ticket.
# Local dev: api isn't behind nginx, so point straight at it.
# Production: infra/nginx/nginx.conf proxies /ws/ on the public domain to the
# api container — set this to a same-origin path instead, e.g.
# NEXT_PUBLIC_WS_URL=wss://app.javobai.uz/ws/inbox
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/inbox

# WS_TICKET_TTL_SECONDS (api) — how long a /auth/ws-ticket is valid for
# before /ws/inbox must consume it. Defaults to 60s if unset.
WS_TICKET_TTL_SECONDS=60

# ─── WhatsApp Cloud API (Phase 9) ────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=javobai_wa_verify_change_me
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Meta shared verify token (Phase 10 — IG + FB) ──────────────────────────
META_VERIFY_TOKEN=javobai_meta_verify_change_me
META_APP_SECRET=

# ─── Agentic (Phase 11) ──────────────────────────────────────────────────────
ACTION_TIMEOUT_SECONDS=10
