# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://javobai:secret@localhost:5432/javobai
POSTGRES_USER=javobai
POSTGRES_PASSWORD=secret
POSTGRES_DB=javobai

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_64_char_string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
OTP_TTL_SECONDS=300

# ─── Auth cookies (Phase 6) ───────────────────────────────────────────────────
# COOKIE_SECURE=false in local dev (HTTP); true in prod (HTTPS).
# COOKIE_DOMAIN empty in dev; set to ".javobai.uz" in prod so the cookie crosses subdomains.
# COOKIE_SAMESITE lax (default), strict, or none.
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# ─── Encryption (Fernet key — run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=change_me_to_fernet_key

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_WEBHOOK_SECRET=change_me_random_32_chars

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=change_me_random_32_chars

# ─── AI / LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=15
EMBEDDINGS_MODEL=BAAI/bge-m3

# ─── Payments ────────────────────────────────────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_KEY=
PAYME_TEST_KEY=

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
